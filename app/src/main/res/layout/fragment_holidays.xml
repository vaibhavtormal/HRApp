<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/nav_header"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_history"
            app:tint="@color/white"
            android:rotation="180"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Holiday Calendar"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- View Toggles (Calendar / List) -->
    <LinearLayout
        android:id="@+id/layout_toggles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintTop_toBottomOf="@id/nav_header">

        <Button
            android:id="@+id/btn_toggle_calendar"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:backgroundTint="@color/primary"
            android:text="Calendar View"
            android:textColor="@color/white"
            android:textSize="12sp"
            app:cornerRadius="12dp"/>

        <Button
            android:id="@+id/btn_toggle_list"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="List View"
            android:textColor="@color/white"
            android:textSize="12sp"
            app:strokeColor="@color/border_dark"
            app:cornerRadius="12dp"/>
    </LinearLayout>

    <!-- Container 1: Calendar View -->
    <LinearLayout
        android:id="@+id/container_calendar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/text_design_by"
        app:layout_constraintTop_toBottomOf="@id/layout_toggles">

        <CalendarView
            android:id="@+id/calendar_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_dark" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/surface_dark"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:id="@+id/text_selected_date_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATE LOG DETAILS"
                    android:textColor="@color/text_sub_dark"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/text_calendar_holiday_details"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="No company holidays on this date."
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Container 2: List View -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_holidays_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/text_design_by"
        app:layout_constraintTop_toBottomOf="@id/layout_toggles"
        tools:listitem="@layout/item_holiday" />

    <!-- Design By Footer -->
    <TextView
        android:id="@+id/text_design_by"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Designed with ♥ by Vaibhav Tormal"
        android:textSize="11sp"
        android:letterSpacing="0.06"
        android:textColor="#80FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="8dp"
    />

</androidx.constraintlayout.widget.ConstraintLayout>
