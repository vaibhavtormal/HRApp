<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/surface_dark">

    <!-- Date selector -->
    <TextView
        android:id="@+id/dialog_text_date"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/badge_role_employee"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:text="Tap to select Date..."
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Reason spinner label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Reason for correction"
        android:textColor="@color/text_sub_dark"
        android:textSize="12sp"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/dialog_spinner_reason"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:backgroundTint="@color/white" />

    <!-- Remarks input -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Explanation remarks"
        android:textColor="@color/text_sub_dark"
        android:textSize="12sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/dialog_edit_remarks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:hint="Provide details here..."
        android:textColor="@color/white"
        android:textColorHint="@color/text_sub_dark"
        android:backgroundTint="@color/border_dark"
        android:inputType="textMultiLine"
        android:lines="3"
        android:gravity="top"
        android:textSize="14sp"/>

    <!-- Document attachment -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Supporting attachment (Optional)"
        android:textColor="@color/text_sub_dark"
        android:textSize="12sp"
        android:textStyle="bold" />

    <androidx.cardview.widget.CardView
        android:id="@+id/dialog_card_attachment"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="@color/bg_dark"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="8dp">

            <TextView
                android:id="@+id/dialog_text_attachment_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Attach Supporting Image"
                android:textColor="@color/primary_light"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
