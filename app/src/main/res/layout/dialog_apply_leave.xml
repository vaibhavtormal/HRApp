<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/surface_dark">

    <!-- Leave Type selection -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Leave Category"
        android:textColor="@color/text_sub_dark"
        android:textSize="12sp"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/dialog_spinner_leave_type"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:backgroundTint="@color/white" />

    <!-- Date selector range -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Date Range"
        android:textColor="@color/text_sub_dark"
        android:textSize="12sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <!-- From Date -->
        <TextView
            android:id="@+id/dialog_text_from_date"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/badge_role_employee"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="From Date..."
            android:textColor="@color/white"
            android:textSize="13sp" />

        <!-- To Date -->
        <TextView
            android:id="@+id/dialog_text_to_date"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/badge_role_employee"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="To Date..."
            android:textColor="@color/white"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Reason input -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Reason for leave"
        android:textColor="@color/text_sub_dark"
        android:textSize="12sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/dialog_edit_leave_reason"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:hint="Provide detailed explanation..."
        android:textColor="@color/white"
        android:textColorHint="@color/text_sub_dark"
        android:backgroundTint="@color/border_dark"
        android:inputType="textMultiLine"
        android:lines="3"
        android:gravity="top"
        android:textSize="14sp"/>

    <!-- Document attachment -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Supporting attachment (Optional)"
        android:textColor="@color/text_sub_dark"
        android:textSize="12sp"
        android:textStyle="bold" />

    <androidx.cardview.widget.CardView
        android:id="@+id/dialog_card_leave_attachment"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="@color/bg_dark"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="8dp">

            <TextView
                android:id="@+id/dialog_text_leave_attachment_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Add Document (PDF/Image)"
                android:textColor="@color/primary_light"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
