<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Staff Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_staff_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Employee Name"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_staff_id_role"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="EMP102 | Role: EMPLOYEE"
                android:textColor="@color/primary_light"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_staff_dept_designation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Product Engineering - Senior Engineer"
                android:textColor="@color/text_main_dark"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_staff_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="employee@company.com"
                android:textColor="@color/text_sub_dark"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Right Side: Edit Actions & Toggle -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_login_access"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/text_access_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Login Access"
                android:textColor="@color/text_sub_dark"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />

            <ImageView
                android:id="@+id/btn_edit_staff"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_settings"
                app:tint="@color/accent_gold" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
