<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/bg_dialog_card">

        <!-- Dialog Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <androidx.cardview.widget.CardView
                android:layout_width="48dp"
                android:layout_height="48dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#1AFFFFFF"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_admin"
                    android:contentDescription="Employee Icon" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Register Account"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Onboard a new employee to system"
                    android:textColor="@color/text_sub_dark"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Employee Full Name Input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Employee Full Name"
            android:textColor="@color/text_sub_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/dialog_emp_name"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Full Name..."
            android:textColor="@color/white"
            android:textColorHint="@color/text_sub_dark"
            android:background="@drawable/bg_dialog_input"
            android:paddingHorizontal="16dp"
            android:inputType="textPersonName"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Email Input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Corporate Email"
            android:textColor="@color/text_sub_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/dialog_emp_email"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="email@company.com..."
            android:textColor="@color/white"
            android:textColorHint="@color/text_sub_dark"
            android:background="@drawable/bg_dialog_input"
            android:paddingHorizontal="16dp"
            android:inputType="textEmailAddress"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Employee Type Input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Employee Type"
            android:textColor="@color/text_sub_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_dialog_input"
            android:layout_marginBottom="16dp"
            android:paddingHorizontal="8dp">

            <Spinner
                android:id="@+id/dialog_spinner_emp_type"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:backgroundTint="@color/white" />
        </FrameLayout>

        <!-- Shift Type Input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Work Shift Type"
            android:textColor="@color/text_sub_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_dialog_input"
            android:layout_marginBottom="16dp"
            android:paddingHorizontal="8dp">

            <Spinner
                android:id="@+id/dialog_spinner_emp_shift"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:backgroundTint="@color/white" />
        </FrameLayout>

        <!-- Employee ID Input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Employee ID / Card ID"
            android:textColor="@color/text_sub_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/dialog_emp_id"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="EMP102..."
            android:textColor="@color/white"
            android:textColorHint="@color/text_sub_dark"
            android:background="@drawable/bg_dialog_input"
            android:paddingHorizontal="16dp"
            android:inputType="text"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Designation Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Designation Title"
            android:textColor="@color/text_sub_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_dialog_input"
            android:layout_marginBottom="16dp"
            android:paddingHorizontal="8dp">

            <Spinner
                android:id="@+id/dialog_spinner_emp_designation"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:backgroundTint="@color/white" />
        </FrameLayout>

        <!-- Department Division -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Department Division"
            android:textColor="@color/text_sub_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_dialog_input"
            android:layout_marginBottom="16dp"
            android:paddingHorizontal="8dp">

            <Spinner
                android:id="@+id/dialog_spinner_emp_dept"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:backgroundTint="@color/white" />
        </FrameLayout>

        <!-- Reporting Manager -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reporting Manager"
            android:textColor="@color/text_sub_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_dialog_input"
            android:layout_marginBottom="16dp"
            android:paddingHorizontal="8dp">

            <Spinner
                android:id="@+id/dialog_spinner_emp_reporting_manager"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:backgroundTint="@color/white" />
        </FrameLayout>

        <!-- Mobile Input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mobile Contact Number"
            android:textColor="@color/text_sub_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/dialog_emp_mobile"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="+91 9876543210..."
            android:textColor="@color/white"
            android:textColorHint="@color/text_sub_dark"
            android:background="@drawable/bg_dialog_input"
            android:paddingHorizontal="16dp"
            android:inputType="phone"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Joining Date -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Joining Date"
            android:textColor="@color/text_sub_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/dialog_emp_joining_date"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Select Joining Date..."
            android:textColor="@color/white"
            android:textColorHint="@color/text_sub_dark"
            android:background="@drawable/bg_dialog_input"
            android:paddingHorizontal="16dp"
            android:focusable="false"
            android:clickable="true"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Birthday Date -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Birthday Date"
            android:textColor="@color/text_sub_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/dialog_emp_birthday"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Select Birthday Date..."
            android:textColor="@color/white"
            android:textColorHint="@color/text_sub_dark"
            android:background="@drawable/bg_dialog_input"
            android:paddingHorizontal="16dp"
            android:focusable="false"
            android:clickable="true"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Spinner Role -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Access Control Role"
            android:textColor="@color/text_sub_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_dialog_input"
            android:layout_marginBottom="8dp"
            android:paddingHorizontal="8dp">

            <Spinner
                android:id="@+id/dialog_spinner_emp_role"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:backgroundTint="@color/white" />
        </FrameLayout>

    </LinearLayout>
</ScrollView>
