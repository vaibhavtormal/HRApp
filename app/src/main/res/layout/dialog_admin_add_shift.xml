<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/bg_dialog_card">

        <!-- Dialog Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <androidx.cardview.widget.CardView
                android:layout_width="48dp"
                android:layout_height="48dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#1AFFFFFF"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/dialog_header_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_history"
                    android:contentDescription="Shift Icon" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/dialog_header_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Configure Shift"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dialog_header_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Set work shift names and timings"
                    android:textColor="@color/text_sub_dark"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Shift Name Input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shift Name"
            android:textColor="@color/text_sub_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/dialog_shift_name"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Enter shift name (e.g. Morning Shift)..."
            android:textColor="@color/white"
            android:textColorHint="@color/text_sub_dark"
            android:background="@drawable/bg_dialog_input"
            android:paddingHorizontal="16dp"
            android:inputType="text"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Start Time Select -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start Time"
            android:textColor="@color/text_sub_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/dialog_shift_start_time"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_dialog_input"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="Tap to select Start Time..."
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- End Time Select -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="End Time"
            android:textColor="@color/text_sub_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/dialog_shift_end_time"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_dialog_input"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="Tap to select End Time..."
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</ScrollView>
